# - 134 (0x86): Router Advertisement (RA)
# - 135 (0x87): Neighbor Solicitation (NS)
# Esta regra foca explicitamente em RA (134) pra nao confundir com NS flood.
alert icmp any any -> ff02::1 any (msg:"ATAQUE -> IPv6 RA Flood (Alta Frequencia)"; flow:stateless; itype:134; detection_filter:track by_dst, count 80, seconds 5; sid:1009611; rev:3;)
