# ========================================
# Zenoh Pico Fragment Bomb
# ========================================
# O ataque envia fragmentos UDP incompletos com byte de controle 0x61
# (Z_MSG_FRAGMENT=0x01 | Z_FLAG_MORE=0x40 | Z_FLAG_RELIABLE=0x20) para a porta
# 7447/UDP (protocolo Zenoh), com Z_FLAG_MORE sempre setada e sem fragmento final,
# esgotando os buffers de remontagem do roteador Zenoh (eclipse/zenoh).
# Origem: 4 threads × 50 fragmentos/lote, tamanhos 512/1024/2048 bytes.

# Fragmento incompleto Zenoh em alta frequência (byte 0x61 = MORE sempre setado)
alert udp any any -> any 7447 (msg:"ATAQUE -> Zenoh Fragment Bomb (fragmentos incompletos)"; content:"|61|"; depth:1; detection_filter:track by_src, count 50, seconds 5; classtype:attempted-dos; sid:1000210; rev:1;)

# Fragmento Zenoh grande (>= 512 bytes) com flag MORE sempre setada
alert udp any any -> any 7447 (msg:"ATAQUE -> Zenoh Fragment Bomb (fragmento grande incompleto)"; content:"|61|"; depth:1; dsize:>512; classtype:attempted-dos; sid:1000211; rev:1;)

# Flood volumétrico de UDP na porta Zenoh independente de conteúdo
alert udp any any -> any 7447 (msg:"ATAQUE -> Zenoh UDP Flood (alta frequência porta 7447)"; detection_filter:track by_src, count 200, seconds 5; classtype:attempted-dos; sid:1000212; rev:1;)
