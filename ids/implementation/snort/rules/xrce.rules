# ============================================================
# XRCE-DDS / RTPS — Generic Attack Detection
# ============================================================

# Resposta envenenada saindo da porta 7400 com GUID falso
alert udp any 7400 -> any any (msg:"LOCAL XRCE-DDS Discovery Poison - fake GUID response"; content:"RTPS"; content:"|42 42 42 42|"; detection_filter:track by_src, count 3, seconds 10; sid:1000080; rev:2;)

# Agente rogue respondendo na porta 6666
alert udp any 6666 -> any any (msg:"LOCAL XRCE-DDS Discovery Poison - Rogue Agent"; content:"RTPS"; detection_filter:track by_src, count 3, seconds 10; sid:1000081; rev:2;)

# Broadcast envenenado para porta de descoberta RTPS (7400)
alert udp any any -> any 7400 (msg:"LOCAL XRCE-DDS Discovery Poison - RTPS fake GUID on discovery port"; content:"RTPS"; content:"|42 42 42 42|"; detection_filter:track by_src, count 3, seconds 10; sid:1000107; rev:1;)

# 1. Sessões XRCE-DDS em volume anormal
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS CREATE_SESSION Flood"; content:"|00 00 00 00|"; detection_filter:track by_src, count 10, seconds 5; sid:1000082; rev:1;)

# 2. XML de entidades DDS em volume
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Entity Flood - XML Entity Creation"; content:"<dds>"; detection_filter:track by_src, count 50, seconds 10; sid:1000083; rev:1; )

# 3. Padrão de nome de participant do ataque
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Entity Flood - Flood Participant Pattern"; content:"flood_p_"; detection_filter:track by_src, count 10, seconds 5; sid:1000084; rev:1;)

# 4. Padrão de nome de topic do ataque
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Entity Flood - Flood Topic Pattern"; content:"FloodTopic_"; detection_filter:track by_src, count 10, seconds 5; sid:1000085; rev:1;)


alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Fragment Abuse - session key FFFF1234"; content:"|FF FF 12 34|"; detection_filter:track by_src, count 5, seconds 10; sid:1000086; rev:1;)

alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Fragment Abuse - OVERLAPPING_FRAGMENT"; content:"OVERLAPPING_FRAGMENT_"; detection_filter:track by_src, count 5, seconds 10; sid:1000087; rev:1;)

alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Fragment Abuse - FLOOD_MESSAGE"; content:"FLOOD_MESSAGE_"; detection_filter:track by_src, count 20, seconds 5; sid:1000088; rev:1;)

alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Malformed Inject - DEADBEEF"; content:"|DE AD BE EF|"; detection_filter:track by_src, count 5, seconds 10; sid:1000089; rev:1;)

alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Malformed Inject - format string"; content:"%x%x%x"; detection_filter:track by_src, count 3, seconds 10; sid:1000090; rev:1;)

alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Malformed Inject - key 0x0BADC0DE"; content:"|0B AD C0 DE|"; detection_filter:track by_src, count 3, seconds 10; sid:1000091; rev:1;)

alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Session Hijack - HACKED_PARTICIPANT"; content:"HACKED_PARTICIPANT"; detection_filter:track by_src, count 3, seconds 10; sid:1000092; rev:1;)

alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Session Hijack - INJECTED_MESSAGE"; content:"INJECTED_MESSAGE_"; detection_filter:track by_src, count 5, seconds 10; sid:1000093; rev:1;)

alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Session Hijack - key 0xAAAABBBB"; content:"|AA AA BB BB|"; detection_filter:track by_src, count 3, seconds 10; sid:1000094; rev:1;)

alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Session Hijack - key 0xCAFEBABE"; content:"|CA FE BA BE|"; detection_filter:track by_src, count 3, seconds 10; sid:1000095; rev:1;)

alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Time Desync - malicious session key prefix"; content:"|71 E0|"; detection_filter:track by_src, count 15, seconds 10; sid:1000096; rev:1;)

alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS UDP DoS - Ping Flood"; detection_filter:track by_src, count 200, seconds 1; sid:1000097; rev:1;)
