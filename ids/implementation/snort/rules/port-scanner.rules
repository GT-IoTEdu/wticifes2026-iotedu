# SNMP community "public" — credencial padrao IoT/infra
alert udp $EXTERNAL_NET any -> $HOME_NET 161 (
    msg:"GT-IoTEdu Port Scanner Vuln - SNMP community public externo";
    content:"public";
    classtype:attempted-recon;
    priority:1;
