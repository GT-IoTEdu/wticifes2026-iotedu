# ==============================================================================
# CoAP GET Flood
# ==============================================================================

# Detecta qualquer origem para destino (Restrito a pacotes pequenos)
alert udp any any -> any 5683 (msg:"ATAQUE -> COAP GET FLOOD (Generico)"; dsize:4<>9; byte_test:1,=,1,1; classtype:attempted-dos; sid:1000301; rev:2;)

# Detecta direção da rede
alert udp $EXTERNAL_NET any -> $HOME_NET 5683 (msg:"ATAQUE -> COAP GET FLOOD (Direção)"; dsize:4<>9; byte_test:1,=,1,1; classtype:attempted-dos; sid:1000302; rev:2;)

# Detecta com validação de tamanho de pacote (Já embutida na faixa)
alert udp $EXTERNAL_NET any -> $HOME_NET 5683 (msg:"ATAQUE -> COAP GET FLOOD (Validacao de Tamanho)"; dsize:4<>9; byte_test:1,=,1,1; classtype:attempted-dos; sid:1000303; rev:2;)

# Detecta com validação de payload
alert udp $EXTERNAL_NET any -> $HOME_NET 5683 (msg:"ATAQUE -> COAP GET FLOOD (Otimizada)"; metadata:service coap; dsize:4<>9; isdataat:2; byte_test:1,=,1,1; classtype:attempted-dos; sid:1000304; rev:2;)

# Detecta com verificação estrita de versão do protocolo
alert udp $EXTERNAL_NET any -> $HOME_NET 5683 (msg:"ATAQUE -> COAP GET FLOOD (Estrita v1)"; metadata:service coap; dsize:4<>9; isdataat:2; byte_test:1,&,64,0; byte_test:1,=,1,1; classtype:attempted-dos; sid:1000305; rev:2;)
