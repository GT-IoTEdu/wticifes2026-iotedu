# ===========================================================================
# Arquivo  : web-simple-scanner.rules
# Descrição: Detecção de scanners web simples
# Fix v3   : Removido nocase standalone (não suportado após sticky buffer
#            nesta build do Snort 3). Ferramentas enviam User-Agent em case
#            fixo, portanto nocase não é necessário para detecção.
# ===========================================================================

# ---------------------------------------------------------------------------
# User-Agents conhecidos (case fixo conforme enviado pelas ferramentas)
# ---------------------------------------------------------------------------
alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"GT-IoTEdu Web Simple Scanner - User-Agent Nikto detectado";
    flow:to_server,established;
    http_header;
    content:"Nikto";
    classtype:web-application-activity;
    priority:2;
    metadata:tool nikto, technique web-scanning;
    sid:9210001;
    rev:3;
)

alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"GT-IoTEdu Web Simple Scanner - User-Agent nikto (lowercase) detectado";
    flow:to_server,established;
    http_header;
    content:"nikto";
    classtype:web-application-activity;
    priority:2;
    metadata:tool nikto, technique web-scanning;
    sid:9210002;
    rev:3;
)

alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
