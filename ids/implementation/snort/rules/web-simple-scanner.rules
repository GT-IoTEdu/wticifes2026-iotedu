# ---------------------------------------------------------------------------
# Sondagem de caminhos administrativos comuns
# (paths em Linux sao case-sensitive; /admin e /Admin sao diferentes)
# ---------------------------------------------------------------------------
alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"GT-IoTEdu Web Simple Scanner - Sonda URI /admin";
    flow:to_server,established;
    http_uri;
    content:"/admin";
    classtype:web-application-activity;
    priority:3;
    sid:9210010;
    rev:3;
)

alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"GT-IoTEdu Web Simple Scanner - Sonda URI /wp-admin";
    flow:to_server,established;
    http_uri;
    content:"/wp-admin";
    classtype:web-application-activity;
    priority:3;
    sid:9210011;
    rev:3;
)

alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"GT-IoTEdu Web Simple Scanner - Sonda URI /.env";
    flow:to_server,established;
    http_uri;
    content:"/.env";
    classtype:web-application-activity;
    priority:2;
    sid:9210012;
    rev:3;
)

alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"GT-IoTEdu Web Simple Scanner - Sonda URI /phpmyadmin";
    flow:to_server,established;
    http_uri;
    content:"/phpmyadmin";
    classtype:web-application-activity;
    priority:2;
    sid:9210013;
    rev:3;
)

alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"GT-IoTEdu Web Simple Scanner - Sonda URI /actuator (Spring Boot)";
    flow:to_server,established;
    http_uri;
    content:"/actuator";
    classtype:web-application-activity;
    priority:2;
    sid:9210014;
    rev:3;
)

# ---------------------------------------------------------------------------
# Rate-based: multiplos 404 (enumeracao de diretorios)
# ---------------------------------------------------------------------------
alert http $HOME_NET $HTTP_PORTS -> $EXTERNAL_NET any (
    msg:"GT-IoTEdu Web Simple Scanner - Multiplos 404 (20/30s) enumeracao de paths";
    flow:to_client,established;
    http_stat_code;
    content:"404";
    detection_filter:track by_dst, count 20, seconds 30;
    classtype:web-application-activity;
    priority:2;
    metadata:technique directory-enumeration;
    sid:9210020;
    rev:3;
)

# ---------------------------------------------------------------------------
# Rate-based: GET flood de scanner simples
# ---------------------------------------------------------------------------
alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"GT-IoTEdu Web Simple Scanner - Rate alto de requisicoes GET (80/10s)";
    flow:to_server,established;
    http_method;
    content:"GET";
    detection_filter:track by_src, count 80, seconds 10;
    classtype:web-application-activity;
    priority:2;
    metadata:technique web-scanning;
    sid:9210021;
    rev:3;
)

# ---------------------------------------------------------------------------
# Arquivos de backup expostos (via pcre, sem modificador H)
# ---------------------------------------------------------------------------
alert http $EXTERNAL_NET any -> $HOME_NET $HTTP_PORTS (
    msg:"GT-IoTEdu Web Simple Scanner - Sonda de arquivo de backup (.bak/.old/.sql)";
    flow:to_server,established;
    http_uri;
    pcre:"/\.(bak|old|sql|dump|orig)(\?|$)/i";
    classtype:web-application-activity;
    priority:2;
    sid:9210031;
    rev:3;
)
