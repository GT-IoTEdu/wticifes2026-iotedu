# REGRAS DE SSH BRUTE FORCE - Suricata

<<<<<<< HEAD
# SSH brute-force: many SYNs to TCP/22 from same src (tentativas rápidas)
# alert tcp any any -> $HOME_NET 22 (msg:"LOCAL SSH Brute-Force - multiple SYNs to SSH port"; flags:S; threshold:type both, track by_src, count 5, seconds 30; sid:1000001; rev:1;)

alert tcp any any -> $HOME_NET 2222 (msg:"LOCAL SSH Brute-Force - multiple SYNs to SSH port"; flow:to_server; flags:S; threshold:type both, track by_src, count 5, seconds 30; sid:1000001; rev:2;)

# SSH brute-force: libssh/header based (complementa a anterior)
alert tcp $EXTERNAL_NET any -> $HOME_NET 2222 (msg:"LOCAL SSH LibSSH Frequent Connections - possible brute"; flow:established,to_server; content:"SSH-"; content:"libssh"; within:20; threshold:type both, track by_src, count 2, seconds 20; sid:1000002; rev:1;)

alert tcp any any -> any 22 (msg:"SSH BRUTE FORCE - Multiplas tentativas porta 22"; flow:to_server; flags:S; threshold: type both, track by_src, count 10, seconds 60; classtype:attempted-admin; sid:2902001; rev:2;)
alert tcp any any -> any 2222 (msg:"SSH BRUTE FORCE - Multiplas tentativas porta 2222"; flow:to_server; flags:S; threshold: type both, track by_src, count 10, seconds 60; classtype:attempted-admin; sid:2902002; rev:2;)
alert tcp any any -> any [22,2222] (msg:"SSH BRUTE FORCE - Ferramenta Hydra/libssh detectada"; flow:to_server,established; content:"libssh"; threshold: type both, track by_src, count 5, seconds 60; classtype:attempted-admin; sid:2902003; rev:1;)
alert tcp any any -> any [22,2222] (msg:"SSH BRUTE FORCE - Ferramenta Ncrack detectada"; flow:to_server,established; content:"Ncrack"; threshold: type both, track by_src, count 3, seconds 30; classtype:attempted-admin; sid:2902004; rev:1;)
alert tcp any any -> any [22,2222] (msg:"SSH BRUTE FORCE - Ataque distribuido SSH"; flow:to_server; flags:S; threshold: type both, track by_dst, count 30, seconds 60; classtype:attempted-admin; sid:2902005; rev:2;)
