# ============================================================
# XRCE-DDS / RTPS — Generic Attack Detection
# ============================================================

# --- DISCOVERY POISON ---
# RTPS magic bytes + GUID fake 0x42424242 na resposta envenenada
# Resposta envenenada saindo da porta 7400 com GUID falso
alert udp any 7400 -> any any (msg:"LOCAL XRCE-DDS Discovery Poison - RTPS fake GUID";content:"RTPS";content:"|42 42 42 42|";distance:0;threshold: type both, track by_src, count 3, seconds 10;sid:1000080; rev:2;)

# Agente rogue respondendo na porta 6666
alert udp any 6666 -> any any (msg:"LOCAL XRCE-DDS Discovery Poison - Rogue Agent Response";content:"RTPS";threshold: type both, track by_src, count 5, seconds 10;sid:1000081; rev:1;)

# Cobre pacotes broadcast/unicast enviados para a porta de descoberta RTPS (7400)
alert udp any any -> any 7400 (msg:"LOCAL XRCE-DDS Discovery Poison - RTPS fake GUID on discovery port";content:"RTPS";content:"|42 42 42 42|";distance:0;threshold: type both, track by_src, count 3, seconds 10;sid:1000107; rev:1;)

# --- ENTITY FLOOD ---
#alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Entity Flood - flood_p_ participant";content:"flood_p_";threshold: type both, track by_src, count 20, seconds 5;sid:1000082; rev:1;)

#alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Entity Flood - FloodTopic";content:"FloodTopic_";threshold: type both, track by_src, count 20, seconds 5;sid:1000083; rev:1;)

# 1. Detecta criação massiva de sessões XRCE-DDS (CREATE_SESSION)
#    Header XRCE: 0x00 0x00 no início + submessage CREATE_SESSION (0x00)
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS CREATE_SESSION Flood"; content:"|00 00 00 00|"; offset:0; depth:4; threshold: type both, track by_src, count 10, seconds 5; sid:1000082; rev:1;)

# 2. Detecta criação de entidades DDS via XML (payload contém "<dds>")
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Entity Flood - XML Entity Creation"; content:"<dds>"; threshold: type both, track by_src, count 50, seconds 10; sid:1000083; rev:1;)

# 3. Detecta criação de participants com padrão do ataque (flood_p_)
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Entity Flood - Flood Participant Pattern"; content:"flood_p_"; threshold: type both, track by_src, count 10, seconds 5; sid:1000084; rev:1;)

# 4. Detecta criação de topics com padrão do ataque (FloodTopic_)
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Entity Flood - Flood Topic Pattern"; content:"FloodTopic_"; threshold: type both, track by_src, count 10, seconds 5;sid:1000085; rev:1;)


# --- FRAGMENT ABUSE ---
# Sessão com key fixa 0xFFFF1234
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Fragment Abuse - known session key";content:"|FF FF 12 34|";threshold: type both, track by_src, count 5, seconds 10;sid:1000086; rev:1;)

alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Fragment Abuse - OVERLAPPING_FRAGMENT";content:"OVERLAPPING_FRAGMENT_";threshold: type both, track by_src, count 5, seconds 10;sid:1000087; rev:1;)

alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Fragment Abuse - FLOOD_MESSAGE";content:"FLOOD_MESSAGE_";threshold: type both, track by_src, count 20, seconds 5;sid:1000088; rev:1;)

# --- MALFORMED INJECT ---
# Magic bytes do malformed: 0xDEADBEEF
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Malformed Inject - DEADBEEF pattern";content:"|DE AD BE EF|";threshold: type both, track by_src, count 5, seconds 10;sid:1000089; rev:1;)

# Format string attack no payload
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Malformed Inject - format string payload";content:"%x%x%x";threshold: type both, track by_src, count 3, seconds 10;sid:1000090; rev:1;)

# Session key fixa 0x0BADC0DE
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Malformed Inject - known session key 0x0BADC0DE";content:"|0B AD C0 DE|";threshold: type both, track by_src, count 3, seconds 10;sid:1000091; rev:1;)

# --- SESSION HIJACK ---
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Session Hijack - HACKED_PARTICIPANT";content:"HACKED_PARTICIPANT";threshold: type both, track by_src, count 3, seconds 10;sid:1000092; rev:1;)

alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Session Hijack - INJECTED_MESSAGE";content:"INJECTED_MESSAGE_";threshold: type both, track by_src, count 5, seconds 10;sid:1000093; rev:1;)

# Keys conhecidas do hijack: 0xAAAABBBB, 0xDEADBEEF, 0xCAFEBABE
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Session Hijack - known key 0xAAAABBBB";content:"|AA AA BB BB|";threshold: type both, track by_src, count 3, seconds 10;sid:1000094; rev:1;)

alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Session Hijack - known key 0xCAFEBABE";content:"|CA FE BA BE|";threshold: type both, track by_src, count 3, seconds 10;sid:1000095; rev:1;)

# --- TIME DESYNC ---
# 20 processos, keys 0x71E0000X — prefixo fixo
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Time Desync - known key prefix 0x71E0";content:"|71 E0|";offset:0; depth:8;threshold: type both, track by_dst, count 15, seconds 10;sid:1000096; rev:1;)

# 4. Session key do ataque (0x71E0xxxx) no payload XRCE
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Time Desync - malicious session key prefix"; content:"|71 E0|"; threshold: type both, track by_src, count 15, seconds 10; sid:1000097; rev:1;)

# 5. Flood de sync — 20 processos x 100 iterações = 2000 pacotes em ~10s
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS Time Desync - sync request flood"; threshold: type both, track by_src, count 50, seconds 10; sid:1000098; rev:1;)


# --- UDP DoS (PING FLOOD) ---
# uxr_ping usa magic bytes específicos: 0x80 0x00 na abertura XRCE + ping submessage
alert udp any any -> any 8888 (msg:"LOCAL XRCE-DDS UDP DoS - Ping Flood";threshold: type both, track by_src, count 200, seconds 1;sid:1000099; rev:1;)
