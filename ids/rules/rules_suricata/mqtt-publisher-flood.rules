alert tcp any any -> any 1883 (msg:"ATAQUE -> MQTT Publisher Flood (Topico Sequencial)"; flow:to_server,established; content:"Test "; detection_filter:track by_src, count 40, seconds 20; sid:1009628; rev:1;)
