# =====================================================================
# SSL Heartbleed (CVE-2014-0160) - Regras Suricata
# Adaptadas das regras Snort3 community + regras de request customizadas
# =====================================================================

# =====================================================================
# REQUEST: Detecta heartbeat request malicioso (atacante -> servidor)
# Heartbeat record (type 0x18) com payload_length 0x4000 mas record
# length de apenas 3 bytes - assinatura clássica do exploit.
# =====================================================================

alert tcp $EXTERNAL_NET any -> $HOME_NET [443,8443] (msg:"ATAQUE -> SSL Heartbleed (SSLv3 Request)"; flow:to_server,established; content:"|18 03 00 00 03 01 40 00|"; reference:cve,2014-0160; classtype:attempted-recon; sid:1000100; rev:1;)

alert tcp $EXTERNAL_NET any -> $HOME_NET [443,8443] (msg:"ATAQUE -> SSL Heartbleed (TLSv1 Request)"; flow:to_server,established; content:"|18 03 01 00 03 01 40 00|"; reference:cve,2014-0160; classtype:attempted-recon; sid:1000101; rev:1;)

alert tcp $EXTERNAL_NET any -> $HOME_NET [443,8443] (msg:"ATAQUE -> SSL Heartbleed (TLSv1.1 Request)"; flow:to_server,established; content:"|18 03 02 00 03 01 40 00|"; reference:cve,2014-0160; classtype:attempted-recon; sid:1000102; rev:1;)

alert tcp $EXTERNAL_NET any -> $HOME_NET [443,8443] (msg:"ATAQUE -> SSL Heartbleed (TLSv1.2 Request)"; flow:to_server,established; content:"|18 03 03 00 03 01 40 00|"; reference:cve,2014-0160; classtype:attempted-recon; sid:1000103; rev:1;)

# =====================================================================
# RESPONSE: Detecta heartbeat response grande (servidor -> atacante)
# Primeiro conjunto: só heartbeat record no início do pacote
# =====================================================================

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (msg:"ATAQUE -> SSL Heartbleed SSLv3 Large Response"; flow:to_client,established; content:"|18 03 00|"; depth:3; byte_test:2,>,128,0,relative; content:"|02|"; within:1; distance:2; reference:cve,2014-0160; classtype:attempted-recon; sid:30514; rev:11;)

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (msg:"ATAQUE -> SSL Heartbleed TLSv1 Large Response"; flow:to_client,established; content:"|18 03 01|"; depth:3; byte_test:2,>,128,0,relative; content:"|02|"; within:1; distance:2; reference:cve,2014-0160; classtype:attempted-recon; sid:30515; rev:11;)

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (msg:"ATAQUE -> SSL Heartbleed TLSv1.1 Large Response"; flow:to_client,established; content:"|18 03 02|"; depth:3; byte_test:2,>,128,0,relative; content:"|02|"; within:1; distance:2; reference:cve,2014-0160; classtype:attempted-recon; sid:30516; rev:11;)

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (msg:"ATAQUE -> SSL Heartbleed TLSv1.2 Large Response"; flow:to_client,established; content:"|18 03 03|"; depth:3; byte_test:2,>,128,0,relative; content:"|02|"; within:1; distance:2; reference:cve,2014-0160; classtype:attempted-recon; sid:30517; rev:11;)

# =====================================================================
# RESPONSE: Heartbeat response precedido de handshake (0x16) ou app data (0x17)
# =====================================================================

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (msg:"ATAQUE -> SSL Heartbleed (SSLv3 Large Response)"; flow:to_client,established; content:"|16 03 00|"; byte_jump:2,0,relative; content:"|18 03 00|"; within:3; fast_pattern; byte_test:2,>,128,0,relative; reference:cve,2014-0160; classtype:attempted-recon; sid:30777; rev:4;)

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (msg:"ATAQUE -> SSL Heartbleed (SSLv3 Large Response)"; flow:to_client,established; content:"|17 03 00|"; byte_jump:2,0,relative; content:"|18 03 00|"; within:3; fast_pattern; byte_test:2,>,128,0,relative; reference:cve,2014-0160; classtype:attempted-recon; sid:30778; rev:4;)

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (msg:"ATAQUE -> SSL Heartbleed (TLSv1 Large Response)"; flow:to_client,established; content:"|16 03 01|"; byte_jump:2,0,relative; content:"|18 03 01|"; within:3; fast_pattern; byte_test:2,>,128,0,relative; reference:cve,2014-0160; classtype:attempted-recon; sid:30779; rev:4;)

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (msg:"ATAQUE -> SSL Heartbleed (TLSv1 Large Response)"; flow:to_client,established; content:"|17 03 01|"; byte_jump:2,0,relative; content:"|18 03 01|"; within:3; fast_pattern; byte_test:2,>,128,0,relative; reference:cve,2014-0160; classtype:attempted-recon; sid:30780; rev:4;)

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (msg:"ATAQUE -> SSL Heartbleed (TLSv1.1 Large Response)"; flow:to_client,established; content:"|16 03 02|"; byte_jump:2,0,relative; content:"|18 03 02|"; within:3; fast_pattern; byte_test:2,>,128,0,relative; reference:cve,2014-0160; classtype:attempted-recon; sid:30781; rev:5;)

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (msg:"ATAQUE -> SSL Heartbleed (TLSv1.1 Large Response)"; flow:to_client,established; content:"|17 03 02|"; byte_jump:2,0,relative; content:"|18 03 02|"; within:3; fast_pattern; byte_test:2,>,128,0,relative; reference:cve,2014-0160; classtype:attempted-recon; sid:30782; rev:4;)

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (msg:"ATAQUE -> SSL Heartbleed (TLSv1.2 Large Response)"; flow:to_client,established; content:"|16 03 03|"; byte_jump:2,0,relative; content:"|18 03 03|"; within:3; fast_pattern; byte_test:2,>,128,0,relative; reference:cve,2014-0160; classtype:attempted-recon; sid:30783; rev:4;)

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (msg:"ATAQUE -> SSL Heartbleed (TLSv1.2 Large Response)"; flow:to_client,established; content:"|17 03 03|"; byte_jump:2,0,relative; content:"|18 03 03|"; within:3; fast_pattern; byte_test:2,>,128,0,relative; reference:cve,2014-0160; classtype:attempted-recon; sid:30784; rev:4;)

# =====================================================================
# RESPONSE: Heartbeat seguido de outro heartbeat
# =====================================================================

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (msg:"ATAQUE -> SSL Heartbleed (SSLv3 Large Response)"; flow:to_client,established; content:"|18 03 00|"; byte_jump:2,0,relative; content:"|18 03 00|"; within:3; byte_test:2,>,128,0,relative; reference:cve,2014-0160; classtype:attempted-recon; sid:30785; rev:4;)

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (msg:"ATAQUE -> SSL Heartbleed (TLSv1 Large Response)"; flow:to_client,established; content:"|18 03 01|"; byte_jump:2,0,relative; content:"|18 03 01|"; within:3; byte_test:2,>,128,0,relative; reference:cve,2014-0160; classtype:attempted-recon; sid:30786; rev:4;)

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (msg:"ATAQUE -> SSL Heartbleed (TLSv1.1 Large Response)"; flow:to_client,established; content:"|18 03 02|"; byte_jump:2,0,relative; content:"|18 03 02|"; within:3; byte_test:2,>,128,0,relative; reference:cve,2014-0160; classtype:attempted-recon; sid:30787; rev:5;)

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (msg:"ATAQUE -> SSL Heartbleed (TLSv1.2 Large Response)"; flow:to_client,established; content:"|18 03 03|"; byte_jump:2,0,relative; content:"|18 03 03|"; within:3; byte_test:2,>,128,0,relative; reference:cve,2014-0160; classtype:attempted-recon; sid:30788; rev:5;)

# =====================================================================
# Masscan Heartbleed exploit detection
# =====================================================================

alert tcp $EXTERNAL_NET any -> $HOME_NET [443,8443] (msg:"ATAQUE -> SSL Heartbleed Masscan Exploit"; flow:to_server,established; content:"[masscan/1.0]"; reference:cve,2014-0160; classtype:attempted-recon; sid:30549; rev:2;)
