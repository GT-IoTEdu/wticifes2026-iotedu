# Tirado de snort3-community-rules

# 21 Regras diferentes pra heartbleed, cada uma com payload diferente
# Motivação: tentar pegar o máximo de variações possíveis do ataque

# Tem também uma regra pra detectar masscan tentando explorar a vulnerabilidade

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (
	msg:"ATAQUE -> SSL Heartbleed (SSLv3 Large Response)";
	flow:to_client,established,only_stream;
	content:"|18 03 00|",depth 3;
	byte_test:2,>,128,0,relative;
	content:"|02|",within 1,distance 2;
	metadata:policy balanced-ips drop,policy max-detect-ips drop,policy security-ips drop,ruleset community;
	reference:cve,2014-0160;
	classtype:attempted-recon;
	sid:30514;
	rev:11;
)

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (
	msg:"ATAQUE -> SSL Heartbleed (TLSv1 Large Response)";
	flow:to_client,established,only_stream;
	content:"|18 03 01|",depth 3;
	byte_test:2,>,128,0,relative;
	content:"|02|",within 1,distance 2;
	metadata:policy balanced-ips drop,policy max-detect-ips drop,policy security-ips drop,ruleset community;
	reference:cve,2014-0160;
	classtype:attempted-recon;
	sid:30515;
	rev:11;
)

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (
	msg:"ATAQUE -> SSL Heartbleed (TLSv1.1 Large Response)";
	flow:to_client,established,only_stream;
	content:"|18 03 02|",depth 3;
	byte_test:2,>,128,0,relative;
	content:"|02|",within 1,distance 2;
	metadata:policy balanced-ips drop,policy max-detect-ips drop,policy security-ips drop,ruleset community;
	reference:cve,2014-0160;
	classtype:attempted-recon;
	sid:30516;
	rev:11;
)

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (
	msg:"ATAQUE -> SSL Heartbleed (TLSv1.2 Large Response)";
	flow:to_client,established,only_stream;
	content:"|18 03 03|",depth 3;
	byte_test:2,>,128,0,relative;
	content:"|02|",within 1,distance 2;
	metadata:policy balanced-ips drop,policy max-detect-ips drop,policy security-ips drop,ruleset community;
	reference:cve,2014-0160;
	classtype:attempted-recon;
	sid:30517;
	rev:11;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET [443,8443] (
	msg:"ATAQUE -> SSL Heartbleed (Masscan)";
	flow:to_server,established;
	content:"[masscan/1.0]";
	metadata:policy balanced-ips drop,policy connectivity-ips drop,policy max-detect-ips drop,policy security-ips drop,ruleset community;
	reference:cve,2014-0160;
	classtype:attempted-recon;
	sid:30549;
	rev:2;
)

# =====================================================================
# Regras de detecção do REQUEST Heartbleed (atacante -> servidor)
# Detecta heartbeat request com payload_length muito grande (0x4000)
# mas record length de apenas 3 bytes - assinatura clássica do exploit.
# =====================================================================

alert tcp $EXTERNAL_NET any -> $HOME_NET [443,8443] (
	msg:"ATAQUE -> SSL Heartbleed (SSLv3 Request)";
	flow:to_server,established;
	content:"|18 03 00 00 03 01 40 00|";
	reference:cve,2014-0160;
	classtype:attempted-recon;
	sid:1000100;
	rev:1;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET [443,8443] (
	msg:"ATAQUE -> SSL Heartbleed (TLSv1 Request)";
	flow:to_server,established;
	content:"|18 03 01 00 03 01 40 00|";
	reference:cve,2014-0160;
	classtype:attempted-recon;
	sid:1000101;
	rev:1;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET [443,8443] (
	msg:"ATAQUE -> SSL Heartbleed (TLSv1.1 Request)";
	flow:to_server,established;
	content:"|18 03 02 00 03 01 40 00|";
	reference:cve,2014-0160;
	classtype:attempted-recon;
	sid:1000102;
	rev:1;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET [443,8443] (
	msg:"ATAQUE -> SSL Heartbleed (TLSv1.2 Request)";
	flow:to_server,established;
	content:"|18 03 03 00 03 01 40 00|";
	reference:cve,2014-0160;
	classtype:attempted-recon;
	sid:1000103;
	rev:1;
)

# =====================================================================
# Regras originais de detecção da RESPOSTA (servidor -> atacante)
# =====================================================================

alert tcp $HOME_NET [21,25,443,465,636,992,993,995,2484,8443] -> $EXTERNAL_NET any (
	msg:"ATAQUE -> SSL Heartbleed (SSLv3 Large Response)";
	flow:to_client,established;
	content:"|16 03 00|";
	byte_jump:2,0,relative;
	content:"|18 03 00|",within 3,fast_pattern;
	byte_test:2,>,128,0,relative;
	metadata:policy balanced-ips drop,policy max-detect-ips drop,policy security-ips drop,ruleset community;
	reference:cve,2014-0160;
	classtype:attempted-recon;
	sid:30777;
	rev:4;
)

