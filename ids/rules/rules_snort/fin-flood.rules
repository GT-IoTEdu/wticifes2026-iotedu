# REGRAS DE FLOOD E SCANS ESPECÍFICOS - Snort 3

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"FIN FLOOD - Alta taxa de pacotes TCP FIN";
    flags:F;
    detection_filter: track by_src, count 2000, seconds 5;
    classtype:denial-of-service;
    sid:1000002; rev:2;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"SYN FLOOD - Alta taxa de pacotes TCP SYN";
    flags:S;
    detection_filter: track by_dst, count 2000, seconds 5;
    classtype:denial-of-service;
    sid:10000099; rev:2;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"NULL SCAN/FLOOD - Nmap ou Hping3 detectado";
    flags:0;
    classtype:attempted-recon;
    sid:1000004; rev:2;
)

alert tcp $EXTERNAL_NET any -> $HOME_NET any (
    msg:"XMAS SCAN/FLOOD - Pacotes com flags FPU";
    flags:FPU;
    classtype:attempted-recon;
    sid:1000005; rev:2;
)
