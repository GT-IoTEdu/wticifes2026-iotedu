# Detecta UNION SELECT
alert http any any -> any $HTTP_PORTS (msg:"ATAQUE -> SQL Injection UNION"; content:"union", nocase; content:"select", nocase; sid:1000029; rev:2;)

# Detecta OR 1=1
alert http any any -> any $HTTP_PORTS (msg:"ATAQUE -> SQL Injection OR 1=1"; content:"or", nocase; content:"1=1", nocase; sid:1000030; rev:2;)

# Detecta aspas simples (comum em SQLi) na URI
alert http any any -> any $HTTP_PORTS (msg:"ATAQUE -> SQL Injection Quote"; content:"'"; http_uri; sid:1000032; rev:2;)
